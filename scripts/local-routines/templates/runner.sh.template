#!/bin/zsh
# Generic runner used by every Insigtrade local routine.
# Reads a prompt file, pipes it through Claude Code in headless mode,
# and appends timestamped output to a per-routine log file.
#
# Args:
#   $1 = routine name (e.g. "daily", "weekly", "monthly")
#
# Expects ~/insigtrade-routines/{name}.prompt.md to exist.

set -uo pipefail
ROUTINE="${1:?routine name required}"
ROUTINE_DIR="$HOME/insigtrade-routines"
PROMPT_FILE="$ROUTINE_DIR/${ROUTINE}.prompt.md"
LOG_DIR="$ROUTINE_DIR/logs"
WRAPPER="$ROUTINE_DIR/claude-wrapper.sh"

mkdir -p "$LOG_DIR"
STAMP=$(date "+%Y-%m-%d_%H%M%S")
LOG_FILE="$LOG_DIR/${ROUTINE}_${STAMP}.log"

if [[ ! -f "$PROMPT_FILE" ]]; then
  echo "[$(date '+%F %T')] missing prompt file: $PROMPT_FILE" >>"$LOG_FILE"
  exit 1
fi

{
  echo "==================== $(date '+%F %T') ===================="
  echo "routine: $ROUTINE"
  echo "prompt:  $PROMPT_FILE"
  echo "claude:  $("$WRAPPER" --version 2>&1 || echo unknown)"
  echo "----------------------------------------------------------"
} >>"$LOG_FILE"

# Run Claude in non-interactive (-p) mode with the prompt piped in.
# --dangerously-skip-permissions: launchd has no TTY for permission prompts.
#   Mitigated because the prompt only needs Bash (curl + jq) + WebFetch.
# --output-format text: keeps the log human-readable.
# --model sonnet: defaults to the latest Sonnet 4.x available.
"$WRAPPER" \
  --print \
  --dangerously-skip-permissions \
  --output-format text \
  --model sonnet \
  --allowedTools "Bash WebFetch Read Write Edit Glob Grep" \
  < "$PROMPT_FILE" \
  >>"$LOG_FILE" 2>&1

EXIT_CODE=$?

{
  echo "----------------------------------------------------------"
  echo "exit_code: $EXIT_CODE"
  echo "finished:  $(date '+%F %T')"
  echo ""
} >>"$LOG_FILE"

exit "$EXIT_CODE"
