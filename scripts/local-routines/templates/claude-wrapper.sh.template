#!/bin/zsh
# Resolves the highest-versioned Claude Code CLI under
# ~/Library/Application Support/Claude/claude-code/<version>/.
# Generated by scripts/local-routines/install.sh — do not edit by hand.

set -euo pipefail
CLAUDE_DIR="$HOME/Library/Application Support/Claude/claude-code"
if [[ ! -d "$CLAUDE_DIR" ]]; then
  echo "Claude Code is not installed at $CLAUDE_DIR" >&2
  echo "Install it from https://claude.com/code first." >&2
  exit 127
fi
LATEST=$(ls -1v "$CLAUDE_DIR" 2>/dev/null | tail -1)
if [[ -z "$LATEST" ]]; then
  echo "No Claude Code version found in $CLAUDE_DIR" >&2
  exit 127
fi
CLAUDE_BIN="$CLAUDE_DIR/$LATEST/claude.app/Contents/MacOS/claude"
if [[ ! -x "$CLAUDE_BIN" ]]; then
  echo "Claude binary not executable: $CLAUDE_BIN" >&2
  exit 127
fi
exec "$CLAUDE_BIN" "$@"
