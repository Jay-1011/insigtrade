# ──────────────────────────────────────────────────────────
# Insigtrade — Environment Variables
# Copy to .env.local for development, set in Vercel dashboard for production
# ──────────────────────────────────────────────────────────

# Public site URL — used in canonical URLs, OG tags, sitemap, JSON-LD
# Production:  https://insigtrade.com
# Dev:         http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin password (single user). Override the default in production!
# Use a strong password — this gates ALL admin write actions.
ADMIN_PASSWORD=insigtrade-admin-2026

# Claude API — powers "Suggest with Claude" + "Generate Blog" in /admin/keywords
# Get a key at https://console.anthropic.com
# Required for: keyword suggestions, AI article generation (admin UI + bulk script)
# ANTHROPIC_API_KEY=sk-ant-...
# Optional override (default: claude-opus-4-7):
# CLAUDE_MODEL=claude-opus-4-7

# Optional — once you wire analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ──────────────────────────────────────────────────────────
# Supabase (database for posts/categories/tools/etc.)
# Project Settings → API → copy Project URL, anon, and service_role
# ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# SECRET — server-only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ──────────────────────────────────────────────────────────
# Cron secret — Bearer token used by /api/cron/* endpoints
# Generate one with: openssl rand -hex 32
# Add the same value to Vercel env vars; the scheduled Claude
# routines paste it into their Authorization header.
# ──────────────────────────────────────────────────────────
CRON_SECRET=replace-me-with-a-64-char-hex-string

# ──────────────────────────────────────────────────────────
# IndexNow — pings Bing + Yandex on every new/updated post
# Generate with: openssl rand -hex 16
# Then place a public/<key>.txt file with the same value as
# its body (the installer below will do that automatically if
# you run scripts/local-routines/install.sh, or you can drop
# it in /public manually). The key is PUBLIC by design — it's
# only an ownership token, not a secret.
# ──────────────────────────────────────────────────────────
INDEXNOW_KEY=replace-with-32-hex-chars
